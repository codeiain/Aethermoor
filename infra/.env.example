# AETHERMOOR — Environment variables template
# Copy to .env and fill in real values. NEVER commit .env to version control.

# Zero-trust inter-service token (generate with: openssl rand -hex 32)
SERVICE_TOKEN=change-me-generate-with-openssl-rand-hex-32

# PostgreSQL
POSTGRES_USER=aethermoor
POSTGRES_PASSWORD=change-me

# Redis
REDIS_PASSWORD=change-me

# Auth service
JWT_SECRET=change-me-generate-with-openssl-rand-hex-64

# Grafana (required in production — docker-compose.prod.yml)
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me

# Timezone (used by Prometheus, Grafana, cAdvisor)
TZ=UTC

# Alertmanager webhook receiver URL (optional — set to enable alert notifications)
# Examples:
#   ntfy (self-hosted):  http://ntfy:80/aethermoor-alerts
#   generic webhook:     https://your-endpoint.example.com/alerts
ALERTMANAGER_WEBHOOK_URL=
